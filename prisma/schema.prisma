generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MASTER
  PLAYER
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum MissionStatus {
  AVAILABLE
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum NPCStatus {
  ALIVE
  DEAD
  MISSING
  UNKNOWN
}

enum FactionRelationType {
  ALLIANCE
  RIVALRY
  NEUTRAL
  HOSTILE
  FRIENDLY
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role     @default(PLAYER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  campaignMembers CampaignMember[]
  masterSessions  GameSession[]    @relation("GameMaster")
  createdNPCs     Npc[]            @relation("Creator")
  notes           Note[]
  auditLogs       AuditLog[]
  accounts        Account[]
  sessions        AuthSession[]
}

model Campaign {
  id          String         @id @default(cuid())
  name        String
  description String?
  coverImage  String?
  status      CampaignStatus @default(ACTIVE)
  avgLevel    Int            @default(1)
  system      String         @default("feiticos-maldicoes-v2.5")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  members     CampaignMember[]
  sessions    GameSession[]
  npcs        Npc[]
  missions    Mission[]
  factions    Faction[]
  locations   Location[]
  timeline    TimelineEvent[]
  wikiPages   WikiPage[]
  notes       Note[]
  auditLogs   AuditLog[]
}

model CampaignMember {
  id         String   @id @default(cuid())
  role       Role     @default(PLAYER)
  joinedAt   DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId])
}

model GameSession {
  id              String   @id @default(cuid())
  number          Int
  summary         String?
  content         String?
  date            DateTime?
  importantEvents String?
  consequences    String?
  nextHooks       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  campaignId      String
  campaign        Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  masterId        String
  master          User        @relation("GameMaster", fields: [masterId], references: [id])

  npcs            SessionNpc[]
}

model Npc {
  id            String   @id @default(cuid())
  name          String
  image         String?
  age           String?
  organization  String?
  objectives    String?
  personality   String?
  backstory     String?
  secrets       String?
  status        NPCStatus @default(ALIVE)
  isPublic      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  campaignId    String
  campaign      Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creatorId     String
  creator       User            @relation("Creator", fields: [creatorId], references: [id])

  relationshipsFrom NpcRelationship[] @relation("FromNPC")
  relationshipsTo   NpcRelationship[] @relation("ToNPC")
  sessions     SessionNpc[]
  locations    LocationNpc[]
}

model NpcRelationship {
  id          String  @id @default(cuid())
  type        String
  description String?

  fromNPCId   String
  fromNPC     Npc     @relation("FromNPC", fields: [fromNPCId], references: [id], onDelete: Cascade)
  toNPCId     String
  toNPC       Npc     @relation("ToNPC", fields: [toNPCId], references: [id], onDelete: Cascade)

  @@unique([fromNPCId, toNPCId])
}

model SessionNpc {
  id        String @id @default(cuid())
  sessionId String
  session   GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  npcId     String
  npc       Npc         @relation(fields: [npcId], references: [id], onDelete: Cascade)

  @@unique([sessionId, npcId])
}

model Mission {
  id          String        @id @default(cuid())
  title       String
  grade       String?
  description String?
  objectives  String?
  reward      String?
  status      MissionStatus @default(AVAILABLE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  campaignId  String
  campaign    Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model Faction {
  id          String   @id @default(cuid())
  name        String
  image       String?
  description String?
  influence   Int      @default(1)
  resources   Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaignId   String
  campaign     Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  relationsFrom FactionRelation[] @relation("FromFaction")
  relationsTo   FactionRelation[] @relation("ToFaction")
}

model FactionRelation {
  id            String              @id @default(cuid())
  type          FactionRelationType
  description   String?

  fromFactionId String
  fromFaction   Faction             @relation("FromFaction", fields: [fromFactionId], references: [id], onDelete: Cascade)
  toFactionId   String
  toFaction     Faction             @relation("ToFaction", fields: [toFactionId], references: [id], onDelete: Cascade)

  @@unique([fromFactionId, toFactionId])
}

model Location {
  id          String   @id @default(cuid())
  name        String
  image       String?
  description String?
  mapData     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaignId  String
  campaign    Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  events      TimelineEvent[]
  npcs        LocationNpc[]
}

model LocationNpc {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  npcId      String
  npc        Npc      @relation(fields: [npcId], references: [id], onDelete: Cascade)

  @@unique([locationId, npcId])
}

model TimelineEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime?
  dateText    String?
  order       Int
  type        String   @default("event")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  locationId  String?
  location    Location? @relation(fields: [locationId], references: [id])
}

model WikiPage {
  id          String   @id @default(cuid())
  title       String
  slug        String
  content     String?
  type        String
  referenceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, slug])
}

model Note {
  id        String   @id @default(cuid())
  title     String?
  content   String?
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entity     String
  entityId   String?
  details    Json?
  createdAt  DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
